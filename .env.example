# Agnes API endpoint
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1

# Default model
AGNES_MODEL=agnes-2.0-flash

# API key — DO NOT commit a real value here.
# Inject at runtime via PowerShell:
#   $env:AGNES_API_KEY = "sk-..."
# AGNES_API_KEY=

# Optional SQLite path for the Web backend.
# AGENS_WEB_DB=runtime/web/agens_web.sqlite3
